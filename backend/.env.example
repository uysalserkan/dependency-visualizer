# Environment variables
DEBUG=false
CACHE_TTL_DAYS=7
MAX_PROJECT_SIZE_GB=10
PARALLEL_PARSE_THRESHOLD=10

# Extractor backend: auto (use Go if available), python, or go
# EXTRACTOR_BACKEND=auto
# Optional: path to Go extractor binary (required when EXTRACTOR_BACKEND=go)
# GO_EXTRACTOR_PATH=/path/to/import_visualizer/extractor/extractor

# Repository analysis (online Git URL)
REPOSITORY_ANALYSIS_ENABLED=true
# Allowed Git hosts (comma-separated). Empty = allow all hosts (useful for private Git servers)
REPOSITORY_ALLOWED_HOSTS=github.com,gitlab.com,bitbucket.org,gitea.com,codeberg.org,bitbucket.int.sahibinden.com
# For private/custom Git servers, add your host: bitbucket.mycompany.com
# Or set to empty to allow all: REPOSITORY_ALLOWED_HOSTS=
REPOSITORY_CLONE_TIMEOUT=120
REPOSITORY_CLONE_DEPTH=1
REPOSITORY_MAX_SIZE_MB=500

# Security (uncomment and set for production)
# ALLOWED_PROJECT_DIRS=/allowed/path1,/allowed/path2
